# ───────── 操作系统 ─────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ───────── Node / Remotion 通用 ─────────
node_modules/
dist/
out/
.env
.env.local
.env.*.local

# ───────── 渲染产物（已通过 remotion.config.ts 输出到 out/）─────────
*.mp4
*.mov
*.webm
*.gif
!docs/**/*.gif
!docs/**/*.mp4
# 例外：Remotion 静态资源目录的视频必须进 git（小于 20MB，渲染输入）
!remotion/public/**/*.mov
!remotion/public/**/*.mp4

# ───────── 视频草稿（用户在 resources/videos/ 提供，不进 git）─────────
# 这些是用户拍摄的训练视频，占空间大，由用户本地管理
resources/videos/*
!resources/videos/.gitkeep

# ───────── 音频素材（mmx 生成 + 用户提供）─────────
# 默认忽略 audios/*（用户录音 / 大文件 / 隐私）
resources/audios/*
!resources/audios/.gitkeep
!resources/audios/bgm/
!resources/audios/bgm/.gitkeep
# 例外：mmx 生成的旁白/BGM（小、可重现、与代码同步）必须进 git
!resources/audios/winged_scapula_b3*.mp3
!resources/audios/winged_scapula_b3*.wav
!resources/audios/bgm/power_build.mp3
!resources/audios/bgm/cyber_pulse*.mp3
!resources/audios/bgm/quiet_think*.mp3
!resources/audios/bgm/hop_pulse*.mp3

# ───────── 图片素材（mmx 生成 + 用户截图）─────────
# 默认忽略 images/*（用户截图 / 大文件 / 临时）
resources/images/*
!resources/images/.gitkeep
# 例外：mmx 生成的数据卡 / 示意（按场景命名）必须进 git
!resources/images/winged_scapula_b3_*.png
!resources/images/winged_scapula_b3_*.jpg
!resources/images/winged_scapula_*.png
!resources/images/weekly_review_*.png
!resources/images/pr_breakthrough_*.png

# ───────── 临时/中间产物 ─────────
.tmp/
.cache/
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────── Playwright MCP（本地调试截图缓存）─────────
.playwright-mcp/

# ───────── Studio 截图（临时预览）─────────
studio-*.png

# ───────── IDE ─────────
.idea/
.vscode/
*.swp
*.swo
*.iml

# ───────── 不要忽略的例外（重要规则文件必须进 git）─────────
# .gitkeep 文件用于保留空目录结构
!.gitkeep
