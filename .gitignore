# ───────── 操作系统 ─────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ───────── Node / Remotion 通用 ─────────
node_modules/
dist/
out/
.env
.env.local
.env.*.local

# ───────── 渲染产物（已通过 remotion.config.ts 输出到 out/）─────────
*.mp4
*.webm
*.mov
*.webm
*.gif
!docs/**/*.gif
!docs/**/*.mp4
# 例外：Remotion 静态资源目录的视频必须进 git（小于 20MB，渲染输入）
!remotion/public/**/*.mov
!remotion/public/**/*.mp4

# ───────── resources/ 资源管理 ─────────
# 核心规则：assets/（公用）入库，user/（用户专属）不入库
# 详见 resources/README.md

# ===== 公用素材 · 入库 =====
# 默认全量忽略，再用 ! 逐个/逐目录入库
# （目前用白名单方式，简洁安全）
!resources/assets/
!resources/assets/**/*

# ===== 用户素材 · 不入库 =====
# 全量忽略 user/ 整个目录
resources/user/
!resources/user/.gitkeep

# ===== 历史位置兼容（已迁移，新位置在 assets/ 和 user/）=====
# 旧 audios/ / images/ / videos/ 不再使用
resources/audios/
resources/images/
resources/videos/
!resources/.gitkeep

# ───────── 临时/中间产物 ─────────
.tmp/
.cache/
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────── Playwright MCP（本地调试截图缓存）─────────
.playwright-mcp/

# ───────── Studio 截图（临时预览）─────────
studio-*.png

# ───────── IDE ─────────
.idea/
.vscode/
*.swp
*.swo
*.iml

# ───────── 不要忽略的例外（重要规则文件必须进 git）─────────
# .gitkeep 文件用于保留空目录结构
!.gitkeep

remotion/**/*.mp4
remotion/**/**/*.webm
remotion/**/**/*.mov
remotion/**/**/*.gif
# 视频素材可以进库（不超 20MB）；音频 m4a/mp3 不进（隐私 + 大小）
remotion/**/**/*.m4a
remotion/**/**/*.mp3
# 例外：通用 BGM 短小可入库
!remotion/**/**/bgm/*.mp3
!remotion/**/**/bgm/*.json
remotion/**/**/*.wav
